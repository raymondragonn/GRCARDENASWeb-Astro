---
import WhatsAppIcon from './WhatsAppIcon.astro';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand-block">
        <div class="footer-brand-row">
          <span class="footer-brand-mark">GR</span>
          <span class="footer-brand-name">
            <strong>GR Cardenas</strong>
            <span>Construcciones</span>
          </span>
        </div>
        <p class="footer-desc">
          Obra civil, obra mecánica e infraestructura energética. Proyectos llave en mano con
          más de 30 años de experiencia para el sector público y privado.
        </p>
      </div>

      <div>
        <h3 class="footer-col-title">Servicios</h3>
        <ul class="footer-list">
          <li>
            <a href="/servicios">Obra Civil</a>
          </li>
          <li>
            <a href="/servicios">Obra Mecánica e Industrial</a>
          </li>
          <li>
            <a href="/servicios">Protección Anticorrosiva</a>
          </li>
          <li>
            <a href="/servicios">Ingeniería y Proyectos</a>
          </li>
          <li>
            <a href="/renta">Renta de Maquinaria</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="footer-col-title">Empresa</h3>
        <ul class="footer-list">
          <li>
            <a href="/nosotros">Nosotros</a>
          </li>
          <li>
            <a href="/nosotros">Política SSPA</a>
          </li>
          <li>
            <a href="/experiencia">Experiencia y Clientes</a>
          </li>
          <li>
            <a href="/practicas">Prácticas Profesionales</a>
          </li>
          <li>
            <a href="/renta">Servicios Especializados</a>
          </li>
          <li>
            <a href="/contacto">Contacto</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="footer-col-title">Contacto</h3>
        <div class="footer-contact-block">
          <div>
            <div class="footer-contact-label">Oficina · Boca del Río</div>
            José Martí 114, Int. 1, Col. Ejido Primero de Mayo Norte, C.P. 94297, Boca del
            Río, Veracruz.
          </div>
          <div>
            <div class="footer-contact-label">Bodega y patio · La Tinaja</div>
            Carr. Moralito–La Tinaja Km 62, Rancho San Felipe de Jesús, C.P. 95118, La Tinaja,
            Veracruz.
          </div>
          <div class="footer-phones">
            <a href="https://wa.me/2291863819" target="_blank" rel="noopener">+52 (229) 186 3819 · WhatsApp</a>
            <a href="mailto:contacto@grcardenasconstrucciones.com">
              contacto@grcardenasconstrucciones.com
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span class="footer-copyright">
        © 2026 GR Cárdenas Construcciones, S.A. de C.V. · Todos los derechos reservados ·
        <a href="/aviso-de-privacidad">Aviso de Privacidad</a> ·
        <a href="/terminos-y-condiciones">Términos y Condiciones</a>
      </span>
      <div class="social-row">
        <a
          href="https://www.facebook.com/people/GR-C%C3%A1rdenas-Construcciones/61560933210624/"
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
          class="social-btn"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z" />
          </svg>
        </a>
        <a
          href="https://www.instagram.com/gr.cardenas"
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
          class="social-btn"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href="https://wa.me/2291863819"
          target="_blank"
          rel="noopener"
          aria-label="WhatsApp"
          class="social-btn"
        >
          <WhatsAppIcon size={18} />
        </a>
      </div>
    </div>
  </div>

  <a
    href="https://wa.me/2291863819?text=Hola%2C%20me%20gustar%C3%ADa%20solicitar%20informaci%C3%B3n%20sobre%20sus%20servicios."
    target="_blank"
    rel="noopener"
    aria-label="Contactar por WhatsApp"
    class="whatsapp-fab"
  >
    <WhatsAppIcon size={30} />
  </a>
</footer>
