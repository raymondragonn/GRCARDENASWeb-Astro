---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.jsx';
import Faq from '../components/Faq.astro';
import { Image } from 'astro:assets';
import heroImg from '../assets/experiencia/experiencia-vista-aerea-instalacion-02.jpg';

const FAQ_ITEMS = [
  {
    question: '¿Dónde están ubicadas las oficinas de GR Cárdenas Construcciones?',
    answer:
      'Nuestra oficina administrativa está en Boca del Río, Veracruz (José Martí 114, Int. 1), y contamos con un patio operativo y bodega en La Tinaja, Veracruz (Carr. Moralito–La Tinaja Km 62).',
  },
  {
    question: '¿Atienden proyectos fuera de Veracruz?',
    answer:
      'Sí. Contamos con cobertura nacional: nuestra base está en Veracruz, con capacidad de movilización y respuesta en el sureste y en todo el país.',
  },
  {
    question: '¿Cómo puedo solicitar una cotización o hacer una consulta?',
    answer:
      'Puedes escribirnos por WhatsApp, llenar el formulario de esta página o enviarnos un correo a contacto@grcardenasconstrucciones.com; te respondemos con una propuesta técnica y de tiempos.',
  },
];
---

<Layout
  title="Contacto | GR Cárdenas Construcciones — Boca del Río y La Tinaja, Veracruz"
  description="Contacta a GR Cárdenas Construcciones. Oficina en Boca del Río y patio operativo en La Tinaja, Veracruz. Escríbenos por WhatsApp o correo, solicita cotización y consulta nuestra ubicación en Google Maps."
>
  <main id="main">
    <section class="page-hero">
      <div class="container">
        <div class="eyebrow eyebrow--dark">Hablemos de tu obra</div>
        <h1 class="h-display" style={{ fontSize: 'clamp(3rem,10vw,8rem)' }}>
          Contacto
        </h1>
        <p class="lede">
          Cuéntanos sobre tu proyecto. Te respondemos por WhatsApp o correo con una propuesta
          técnica y de tiempos.
        </p>
        <Image src={heroImg} alt="Instalación energética en operación construida por GR Cárdenas" width={1000} class="page-hero-img" />
      </div>
    </section>

    {/* FORM + INFO */}
    <section class="contact-grid">
      <div class="contact-form-panel">
        <h2 class="h-section" style={{ fontSize: 'clamp(1.6rem,3vw,2.4rem)', marginBottom: 'clamp(1.6rem,3vw,2.4rem)' }}>
          Solicita una cotización
        </h2>
        <ContactForm client:visible />
      </div>

      <div class="contact-info-panel">
        <h2 class="h-section" style={{ fontSize: 'clamp(1.6rem,3vw,2.4rem)', marginBottom: 'clamp(1.6rem,3vw,2.4rem)' }}>
          Datos de contacto
        </h2>

        <div class="contact-info-block">
          <div class="footer-contact-label">Oficina administrativa · Boca del Río</div>
          <p style={{ margin: 0, fontSize: '1rem', lineHeight: 1.55, color: 'rgba(255,255,255,.85)' }}>
            José Martí 114, Int. 1, entre Lorenzo Barcelata y Belisario Domínguez, Col. Ejido
            Primero de Mayo Norte, C.P. 94297, Boca del Río, Veracruz.
          </p>
        </div>
        <div class="contact-info-block">
          <div class="footer-contact-label">Bodega y patio operativo · La Tinaja</div>
          <p style={{ margin: 0, fontSize: '1rem', lineHeight: 1.55, color: 'rgba(255,255,255,.85)' }}>
            Carretera Moralito–La Tinaja Km 62, Rancho San Felipe de Jesús, C.P. 95118, La
            Tinaja, Veracruz.
          </p>
        </div>
        <div class="contact-info-block">
          <div class="footer-contact-label">WhatsApp</div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: 6, fontSize: '1.05rem' }}>
            <a href="https://wa.me/2291863819" target="_blank" rel="noopener" style={{ color: '#fff' }}>+52 (229) 186 3819</a>
          </div>
        </div>
        <div class="contact-info-block">
          <div class="footer-contact-label">Correo</div>
          <a href="mailto:contacto@grcardenasconstrucciones.com" style={{ fontSize: '1.05rem', color: '#fff' }}>
            contacto@grcardenasconstrucciones.com
          </a>
        </div>

        <div class="footer-contact-label" style={{ margin: '28px 0 14px' }}>Síguenos</div>
        <div class="social-row">
          <a
            href="https://www.facebook.com/people/GR-C%C3%A1rdenas-Construcciones/61560933210624/"
            target="_blank"
            rel="noopener"
            aria-label="Facebook"
            class="social-btn social-btn--lg"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12Z" />
            </svg>
          </a>
          <a
            href="https://www.instagram.com/gr.cardenas"
            target="_blank"
            rel="noopener"
            aria-label="Instagram"
            class="social-btn social-btn--lg"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a
            href="https://wa.me/2291863819"
            target="_blank"
            rel="noopener"
            aria-label="WhatsApp"
            class="social-btn social-btn--lg"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.5 14.4c-.3-.15-1.77-.87-2.04-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.23 1.36.19 1.87.12.57-.09 1.77-.72 2.02-1.42.25-.7.25-1.29.17-1.42-.07-.13-.27-.2-.57-.35Z" />
            </svg>
          </a>
        </div>
      </div>
    </section>

    {/* MAPA */}
    <section class="section">
      <div class="container section-pad-sm">
        <div style={{ display: 'flex', flexWrap: 'wrap', alignItems: 'baseline', justifyContent: 'space-between', gap: 16, marginBottom: 22 }}>
          <h2 class="h-section" style={{ fontSize: 'clamp(1.6rem,3.4vw,2.6rem)' }}>Ubicación</h2>
          <a
            href="https://www.google.com/maps/search/?api=1&query=GR+CARDENAS+CONSTRUCCIONES+La+Tinaja+Veracruz"
            target="_blank"
            rel="noopener"
            class="link-underline"
            style={{ display: 'inline-flex' }}
          >
            Ver en Google Maps <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="map-placeholder">
          <iframe
            class="map-embed"
            src="https://www.google.com/maps?q=GR+CARDENAS+CONSTRUCCIONES+La+Tinaja+Veracruz&output=embed"
            title="Mapa de ubicación de GR Cárdenas Construcciones, La Tinaja, Veracruz"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        </div>
      </div>
    </section>

    <Faq title="Preguntas frecuentes" items={FAQ_ITEMS} />
  </main>
</Layout>
