const SERVICE_GALLERIES: Record<string, Awaited<ReturnType<typeof buildServiceGallery>>> = {};
for (const s of SERVICE_SECTIONS) {
  SERVICE_GALLERIES[s.id] = await buildServiceGallery(s.id);
}
---

<Layout
  title="Servicios | Obra civil, obra mecánica e infraestructura — GR Cárdenas"
  description="Servicios de GR Cárdenas Construcciones: obra civil, obra mecánica e industrial, infraestructura metálica, obra eléctrica, protección anticorrosiva e ingeniería y proyectos para el sector energético e industrial en Veracruz."
>
  <main id="main">
    <section class="page-hero">
      <div class="container">
        <div class="eyebrow eyebrow--dark">Qué hacemos</div>
        <h1 class="h-display">Servicios</h1>
        <p class="lede">
          Seis líneas de servicio orientadas al sector energético, industrial y de
          infraestructura, con calidad constructiva, seguridad operativa y cumplimiento de
          especificaciones técnicas.
        </p>
        <nav aria-label="Índice de servicios" class="service-anchor-nav">
          {SERVICE_SECTIONS.map((s) => (
            <a href={`#${s.id}`}>
              <span>{s.num}</span> {s.navLabel}
            </a>
          ))}
        </nav>
        <Image src={heroImg} alt="Línea de conducción de hidrocarburos construida por GR Cárdenas" width={1000} class="page-hero-img" />
      </div>
    </section>

    {SERVICE_SECTIONS.map((s) => (
      <section
        id={s.id}
        class={`section${s.dark ? ' section--dark' : ''}`}
        style={{ scrollMarginTop: 90 }}
      >
        <div
          class="container section-pad-sm two-col"
          style={s.reversed ? { gridAutoFlow: 'dense' } : undefined}
        >
          <div style={s.reversed ? { order: 2 } : undefined}>
            <div class="h-section" style={{ fontFamily: 'var(--font-display)', fontSize: 'clamp(3rem,6vw,5rem)', lineHeight: 0.9 }}>
              {s.num}
            </div>
            <h2 class="h-section" style={{ margin: '10px 0 18px', fontSize: 'clamp(1.9rem,4vw,3rem)' }}>
              {s.title.map((line, i) => (
                <Fragment>
                  {i > 0 && <br />}
                  {line}
                </Fragment>
              ))}
            </h2>
            <p class="lede" style={{ margin: '0 0 26px', maxWidth: '44ch' }}>
              {s.intro}
            </p>
            {SERVICE_GALLERIES[s.id].length > 0 ? (
              <Gallery images={SERVICE_GALLERIES[s.id]} dark={s.dark} aspectRatio="4/3" minimal arrows={false} intervalMs={3000} />
            ) : (
              <div class={`photo-placeholder${s.dark ? ' photo-placeholder--dark' : ''}`} style={{ aspectRatio: '4/3' }}>
                <span class={`photo-tag${s.dark ? ' photo-tag--dark' : ''}`}>{s.photoTag}</span>
              </div>
            )}
          </div>

          <div style={s.reversed ? { order: 1 } : undefined}>
            {s.items && (
              <ul class="service-detail-list">
                {s.items.map((item) => (
                  <li class="service-detail-item">
                    <div class="service-detail-title">{item.title}</div>
                    <p class="service-detail-text">{item.text}</p>
                  </li>
                ))}
              </ul>
            )}

            {s.numbered && (
              <ul class="service-detail-list">
                {s.numbered.map((text, i) => (
                  <li class="service-detail-num-item service-detail-item">
                    <span>{String(i + 1).padStart(2, '0')}</span>
                    {text}
                  </li>
                ))}
              </ul>
            )}

            <a
              href={`https://wa.me/2291863819?text=${encodeURIComponent(`Hola, me gustaría solicitar una cotización de ${s.title.join(' ')}.`)}`}
              target="_blank"
              rel="noopener"
              class={`btn btn-sm${s.dark ? ' btn-light' : ' btn-dark'}`}
              style={{ marginTop: 'clamp(1.6rem,3vw,2.2rem)' }}
            >
              Cotizar por WhatsApp <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </section>
    ))}

    {/* CTA */}
    <section class="section">
      <div class="container section-pad-sm">
        <div class="cta-banner" style={{ marginBottom: 'clamp(1.8rem,3vw,2.6rem)' }}>
          <div>
            <h2 class="cta-title" style={{ maxWidth: '20ch' }}>¿Necesitas también renta de maquinaria?</h2>
            <p class="text-muted" style={{ margin: '14px 0 0', fontSize: '1.02rem', maxWidth: '48ch' }}>
              Consulta nuestros servicios especializados y flotilla de equipo pesado.
            </p>
          </div>
          <a href="/renta#especializados" class="btn btn-dark">
            Renta y especializados <span aria-hidden="true">→</span>
          </a>
        </div>
        <div class="maq-examples">
          {MAQUINARIA_EJEMPLOS.map((m) => (
            <a href="/renta#maquinaria" class="maq-card" aria-label={`Ver renta de ${m.title}`}>
              <Image src={m.img} alt={m.title} width={700} />
              <span>{m.title} <span aria-hidden="true">→</span></span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <Faq title="Preguntas frecuentes sobre nuestros servicios" items={FAQ_ITEMS} />
  </main>
</Layout>

<style>
  .maq-examples {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 14px;
  }
  .maq-card {
    border: 2px solid var(--black);
    display: flex;
    flex-direction: column;
    background: var(--white);
    color: var(--black);
    transition: all 0.1s linear;
  }
  .maq-card img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    border-bottom: 2px solid var(--black);
  }
  .maq-card > span {
    padding: 12px 14px;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .maq-card:hover {
    background: var(--black);
    color: var(--white);
  }
</style>
