---
import Layout from '../layouts/Layout.astro';
import Faq from '../components/Faq.astro';
import Gallery from '../components/Gallery.astro';
import { getImage, Image } from 'astro:assets';
import { captionFromFilename, sortByFilename } from '../utils/gallery';
import heroImg from '../assets/servicios/obra-mecanica/obra-mecanica-linea-conduccion-01.jpg';
import maqExcavadora from '../assets/renta/maquinaria/excavadora/excavadora-01.jpg';
import maqRetro from '../assets/renta/maquinaria/retroexcavadora/retroexcavadora-01.jpg';
import maqTitan from '../assets/renta/maquinaria/titan/titan-01.jpg';
import maqHiab from '../assets/renta/maquinaria/grua-hiab/grua-hiab-01.jpg';

const MAQUINARIA_EJEMPLOS = [
  { img: maqExcavadora, title: 'Excavadora' },
  { img: maqRetro, title: 'Retroexcavadora' },
  { img: maqTitan, title: 'Titán' },
  { img: maqHiab, title: 'Grúa Hiab' },
];

const servicePhotoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/servicios/*/*.{jpg,jpeg,png}',
  { eager: true }
);

async function buildServiceGallery(categoryId: string) {
  const entries = sortByFilename(
    Object.entries(servicePhotoModules)
      .filter(([path]) => path.includes(`/servicios/${categoryId}/`))
      .map(([path, mod]) => ({ path, mod }))
  );

  return Promise.all(
    entries.map(async ({ path, mod }) => {
      const filename = path.split('/').pop() ?? '';
      const optimized = await getImage({ src: mod.default, width: 1400, format: 'webp', quality: 78 });
      return {
        src: optimized.src,
        width: optimized.attributes.width as number,
        height: optimized.attributes.height as number,
        caption: captionFromFilename(filename, categoryId),
      };
    })
  );
}

const FAQ_ITEMS = [
  {
    question: '¿GR Cárdenas ejecuta proyectos para PEMEX y CFE?',
    answer:
      'Sí. Contamos con más de 30 años de experiencia y 39 contratos ejecutados desde 1995 para PEMEX, CFE y contratistas EPC del sector energético, además de proyectos para el sector privado.',
  },
  {
    question: '¿Qué incluye el servicio de obra mecánica e industrial?',
    answer:
      'Amarres a pozos de gas de alta presión, líneas de conducción de hidrocarburos, baterías de separación, trampas de diablos, tanques y recipientes a presión, pruebas hidrostáticas y soldadura especializada certificada.',
  },
  {
    question: '¿Realizan protección anticorrosiva para tuberías y tanques?',
    answer:
      'Sí, mediante sandblast (chorro abrasivo), aplicación de recubrimientos industriales y sistemas de protección catódica para ductos y tanques enterrados o sumergidos.',
