    reversed: true,
    items: [
      { title: 'Bodegas industriales', text: 'Para almacenamiento, logística y procesos.' },
      { title: 'Estructuras metálicas', text: 'Fabricación y montaje de estructuras industriales y comerciales.' },
      { title: 'Cobertizos industriales', text: 'Estructura ligera, mediana o pesada según proyecto.' },
      { title: 'Sistemas estructurales especializados', text: 'Armaduras tipo arco, warre y fink para grandes claros.' },
