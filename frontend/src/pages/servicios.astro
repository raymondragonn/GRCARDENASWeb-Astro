];

const SERVICE_SECTIONS = [
  {
    id: 'obra-civil',
    num: '01',
    navLabel: 'Obra Civil',
    title: ['Obra Civil'],
    intro:
      'Proyectos orientados al sector energético, industrial y de infraestructura, garantizando calidad constructiva y cumplimiento de especificaciones técnicas.',
    photoTag: 'Foto · Terracerías / cimentación',
    dark: false,
    items: [
      { title: 'Terracerías y movimiento de tierras', text: 'Preparación de sitios, cortes, rellenos, nivelación y estabilización de suelos.' },
      { title: 'Cimentaciones especializadas', text: 'Superficiales y profundas para equipos críticos, estructuras metálicas y edificaciones.' },
      { title: 'Pavimentos y plataformas industriales', text: 'Losas de concreto reforzado de alta resistencia, plataformas operativas y bases de soporte.' },
      { title: 'Urbanización y obra civil', text: 'Vialidades internas, guarniciones, banquetas, drenajes pluviales y obras complementarias.' },
      { title: 'Mantenimiento y acabados industriales', text: 'Pintura industrial, protección de estructuras y chapeo manual o mecanizado.' },
    ],
  },
  {
    id: 'obra-mecanica',
    num: '02',
    navLabel: 'Obra Mecánica',
    title: ['Obra Mecánica', 'e Industrial'],
    intro:
      'Trabajos especializados para el sector petrolero, gasero e industrial, con soldadura certificada y control de calidad en líneas y equipos.',
    photoTag: 'Foto · Ductos / soldadura',
    dark: true,
    reversed: true,
    numbered: [
      'Amarres a pozos de gas de alta presión',
      'Cabezales de recolección de aceites',
      'Líneas de conducción de hidrocarburos',
      'Baterías de separación',
      'Trampas de diablos (pigging)',
      'Tanques y recipientes a presión',
      'Pruebas hidrostáticas',
      'Soldadura especializada certificada',
      'Soportería industrial',
    ],
  },
  {
    id: 'infra-metalica',
    num: '03',
    navLabel: 'Infra. Metálica',
    title: ['Infraestructura Metálica'],
    intro: 'Herrería e infraestructura metálica para seguridad y protección en instalaciones industriales.',
    photoTag: 'Foto · Cercados / rejillas',
    dark: false,
    items: [
      { title: 'Herrería e infraestructura metálica', text: 'Estructuras metálicas para seguridad y protección de instalaciones.' },
      { title: 'Cercados y accesos', text: 'Cercas de alta resistencia y puertas metálicas industriales.' },
      { title: 'Sistemas de protección', text: 'Barandales y guardacuerpos.' },
      { title: 'Pisos y rejillas industriales tipo Irving', text: 'Rejillas y pisos industriales de alta resistencia.' },
      { title: 'Guardaganados', text: 'Para accesos vehiculares en instalaciones y caminos.' },
    ],
  },
  {
    id: 'obra-electrica',
    num: '04',
    navLabel: 'Obra Eléctrica',
    title: ['Obra Eléctrica'],
    intro: 'Electrificación e instalaciones eléctricas industriales para plantas e instalaciones energéticas.',
    photoTag: 'Foto · Tableros / líneas',
    dark: true,
    reversed: true,
    items: [
      { title: 'Electrificación en alta, media y baja tensión', text: 'Para instalaciones industriales y energéticas.' },
      { title: 'Instalaciones eléctricas industriales', text: 'Cableado, tableros de control, canalizaciones, iluminación y sistemas de distribución.' },
