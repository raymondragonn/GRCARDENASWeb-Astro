---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada | GR Cárdenas Construcciones">
  <main id="main">
    <section class="section-pad container" style={{ textAlign: 'center' }}>
      <h1 class="h-display">404</h1>
      <p class="lede" style={{ margin: '20px auto 0' }}>
        La página que buscas no existe o fue movida.
      </p>
      <a href="/" class="btn btn-dark mt-lg" style={{ margin: '32px auto 0' }}>
        Volver al inicio
      </a>
    </section>
  </main>
</Layout>
